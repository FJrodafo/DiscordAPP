{
  "name": "@fjrodafo/discord-app",
  "version": "1.0.1",
  "description": "A simple Discord Application made in JavaScript!",
  "keywords": [
    "discord",
    "app",
    "npmjs",
    "nodejs",
    "discordjs",
    "javascript",
    "fjrodafo"
  ],
  "homepage": "https://github.com/FJrodafo/DiscordAPP#readme",
  "bugs": {
    "url": "https://github.com/FJrodafo/DiscordAPP/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FJrodafo/DiscordAPP.git"
  },
  "license": "CC0-1.0",
  "author": "FJrodafo - Francisco José Rodríguez Afonso",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node ./src/deploy-commands.js && node ./src/index.js",
    "canary": "node ./canary/deploy-commands.js && node ./canary/index.js",
    "eslint": "eslint './**/*.js'",
    "eslintfix": "eslint './**/*.js' --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "tarball": "npm pack --dry-run",
    "publish:npm": "npm publish --access=public --registry=https://registry.npmjs.org/",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@fjrodafo/port-finder": "^2.0.5",
    "canvas": "^3.2.0",
    "discord.js": "^14.26.2",
    "express": "^5.2.1",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "eslint": "^9.35.0"
  }
}
